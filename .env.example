# Copy to ".env" in the project root and fill in ONE option for best note quality.

# Whisper ASR: "small" or "medium" recommended for Telugu / Indian languages; "base" is faster but weaker.
# WHISPER_MODEL=small
# WHISPER_BEAM_SIZE=5

# --- Recommended: Groq (fast, free tier at https://console.groq.com/) ---
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant
# For harder Telugu→English notes, try a larger model if available on your Groq account, e.g. llama-3.3-70b-versatile

# --- Or: OpenAI or any OpenAI-compatible API (OpenRouter, etc.) ---
# OPENAI_API_KEY=
# OPENAI_BASE_URL=
# OPENAI_MODEL=gpt-4o-mini

# Force a provider: groq | openai | local | heuristic
# CLINICAL_NOTE_PROVIDER=groq

# Optional: tiny local LLM (slow on CPU; set to 1 to download ~1GB on first run)
# USE_LOCAL_CLINICAL_LLM=0
# LOCAL_LLM_MODEL=Qwen/Qwen2.5-0.5B-Instruct
